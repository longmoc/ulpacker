# Google OAuth client id for Drive sync (public value — safe to expose).
# Create one in Google Cloud Console -> APIs & Services -> Credentials ->
# OAuth client ID -> Web application, with these Authorized JavaScript origins:
#   https://longmoc.github.io
#   http://localhost:5173
# Leave empty to run the app local-only (no Google sign-in).
VITE_GOOGLE_CLIENT_ID=
